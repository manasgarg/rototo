{
  "description": "Panel catalog",
  "type": "object",
  "required": [
    "level"
  ],
  "properties": {
    "level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "x-rototo-ui": {
        "widget": "slider",
        "steps": 5
      }
    },
    "mode": {
      "type": "string",
      "enum": ["light", "dark"],
      "x-rototo-ui": {
        "widget": "radio"
      }
    },
    "channel": {
      "type": "string",
      "x-rototo-ui": {
        "widget": "radio"
      }
    }
  }
}
