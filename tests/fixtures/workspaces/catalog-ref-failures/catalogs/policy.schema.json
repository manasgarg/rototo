{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema for policy catalog values.",
  "$id": "rototo://catalogs/policy.schema.json",
  "type": "object",
  "required": [
    "unknown_catalog",
    "unknown_entry",
    "invalid_pointer",
    "missing_pointer",
    "ambiguous_template"
  ],
  "properties": {
    "unknown_catalog": {
      "type": "string",
      "x-rototo-catalog-ref": "missing-template"
    },
    "unknown_entry": {
      "type": "string",
      "x-rototo-catalog-ref": "email-template"
    },
    "invalid_pointer": {
      "type": "string",
      "x-rototo-catalog-ref": "email-template"
    },
    "missing_pointer": {
      "type": "string",
      "x-rototo-catalog-ref": "email-template"
    },
    "ambiguous_template": {
      "type": "string",
      "x-rototo-catalog-ref": [
        "email-template",
        "sms-template"
      ]
    }
  },
  "additionalProperties": false
}
