# rototo console — example environment
#
# Copy to `.env` and fill in what you need. The server reads process.env
# directly, so load this however suits you:
#
#   node --env-file=.env src/main.ts          # Node 24 built-in loader
#   set -a; source .env; set +a; just console-dev
#
# Nothing here is required for local development. With an empty
# environment the server boots in LOCAL mode: no login, listening on
# 127.0.0.1:7687, trusting your workstation's ambient GitHub token (env,
# stored credentials, or `gh auth token`).
#
# Runtime shape — host, port, data-dir, public-url, web bundle — are CLI
# flags, not env vars (`--host`, `--port`, `--data-dir`, `--public-url`,
# `--web`). The one exception is the web-bundle path override at the
# bottom of this file.


# ── Auth mode ────────────────────────────────────────────────────────
# Setting GitHub OAuth or OIDC flips the server from local mode (no
# login) into TEAM mode (real sign-in). Leave both blocks empty for
# local development.

# GitHub OAuth. Set BOTH or neither; setting only one is a startup error.
#ROTOTO_GITHUB_CLIENT_ID=
#ROTOTO_GITHUB_CLIENT_SECRET=

# OIDC / SSO. One generic provider covers Okta, Entra, Google, and the
# rest. ISSUER requires CLIENT_ID and CLIENT_SECRET too. DISPLAY_NAME is
# the label on the sign-in button (defaults to "SSO").
#ROTOTO_CONSOLE_OIDC_ISSUER=https://your-idp.example.com
#ROTOTO_CONSOLE_OIDC_CLIENT_ID=
#ROTOTO_CONSOLE_OIDC_CLIENT_SECRET=
#ROTOTO_CONSOLE_OIDC_DISPLAY_NAME=SSO


# ── Team-mode secrets ────────────────────────────────────────────────
# Encrypts each user's stored token. Required before the first GitHub
# sign-in in team mode. Generate one with: openssl rand -base64 32
#ROTOTO_CONSOLE_TOKEN_ENCRYPTION_KEY=


# ── GitHub App ───────────────────────────────────────────────────────
# Mints installation tokens so the console can act for principals with
# no GitHub credential of their own. Set BOTH or neither. The private
# key is the PEM contents (escape newlines as \n if your loader needs
# single-line values).
#ROTOTO_GITHUB_APP_ID=
#ROTOTO_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# HMAC secret for GitHub webhook nudges. Unset leaves the webhook
# endpoint disabled; the reconciler still polls every couple of minutes.
#ROTOTO_GITHUB_WEBHOOK_SECRET=


# ── Identity & enrollment ────────────────────────────────────────────
# Bootstrap administrators, matched once at first sign-in to mint a
# durable administer grant. Comma-separated identity references:
# `github:<login>` or `oidc:<email>`.
#ROTOTO_CONSOLE_ADMINS=github:manasgarg

# Who gets a principal at sign-in: invite-only (default), domain-allowlist,
# or open.
#ROTOTO_CONSOLE_ENROLLMENT=invite-only

# Verified-email domains that auto-enroll under domain-allowlist. Comma
# list; ignored unless ENROLLMENT is domain-allowlist.
#ROTOTO_CONSOLE_ENROLLMENT_DOMAINS=example.com,corp.example.com


# ── Packages ─────────────────────────────────────────────────────────
# Bearer token for private HTTPS or archive package sources.
#ROTOTO_PACKAGE_TOKEN=


# ── Web bundle ───────────────────────────────────────────────────────
# Path to the built web app to serve. Only needed to override the
# defaults, which are tried in order: the --web flag, then the packaged
# ../web, then the repo's ../../console-web/dist. No bundle found means
# the server runs API-only.
#ROTOTO_CONSOLE_WEB_DIST=/opt/rototo-console/web
