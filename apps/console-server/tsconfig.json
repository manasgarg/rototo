{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": true,
        "rootDir": ".",
        "strict": true,
        "target": "ES2023",
        "types": ["node"],
        "verbatimModuleSyntax": true
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"]
}
