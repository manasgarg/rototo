{
    "name": "@rototo/console-web",
    "version": "0.1.0-alpha.6",
    "description": "The new rototo console frontend: a static SPA over the TypeScript console server.",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc --noEmit && vite build",
        "check": "npm run test && npm run build",
        "dev": "vite",
        "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/*.mjs\" \"*.{json,ts}\" \"index.html\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/*.mjs\" \"*.{json,ts}\" \"index.html\"",
        "lint": "npm run typecheck",
        "test": "node scripts/check-extension-contract.mjs && node --test \"src/lib/router.test.ts\" \"src/extensions/flags/logic.test.ts\" \"src/extensions/table/logic.test.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/language": "^6.12.3",
        "@codemirror/legacy-modes": "^6.5.3",
        "@codemirror/state": "^6.6.0",
        "@lezer/highlight": "^1.2.3",
        "@uiw/react-codemirror": "^4.25.10",
        "react": "19.2.1",
        "react-dom": "19.2.1"
    },
    "devDependencies": {
        "@types/node": "24.10.2",
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "prettier": "^3.8.4",
        "typescript": "6.0.3",
        "vite": "^6.3.0"
    }
}
