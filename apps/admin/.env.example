GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Required before GitHub sign-in. Generate with: openssl rand -base64 32
ROTOTO_ADMIN_TOKEN_ENCRYPTION_KEY=

# Optional. Defaults to http://localhost:3000.
ROTOTO_ADMIN_BASE_URL=http://localhost:3000

# Optional. Defaults to apps/admin/.rototo-admin.
ROTOTO_ADMIN_DATA_DIR=.rototo-admin
