{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Request context contract for request runtime inputs.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "account": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plan": {
          "type": "string"
        },
        "seats": {
          "type": "integer"
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region": {
          "type": "string"
        }
      }
    }
  }
}
