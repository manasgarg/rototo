{
  "description": "Console startup observability profiles",
  "type": "object",
  "required": [
    "enabled",
    "event_sink",
    "tracing",
    "thresholds"
  ],
  "properties": {
    "enabled": {
      "type": "boolean"
    },
    "event_sink": {
      "type": "object",
      "required": [
        "directory",
        "api_events",
        "ui_events",
        "operation_events"
      ],
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "api_events": {
          "type": "boolean"
        },
        "ui_events": {
          "type": "boolean"
        },
        "operation_events": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "tracing": {
      "type": "object",
      "required": [
        "filter",
        "format"
      ],
      "properties": {
        "filter": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "compact",
            "pretty",
            "json"
          ]
        }
      },
      "additionalProperties": false
    },
    "thresholds": {
      "type": "object",
      "required": [
        "api_p95_ms",
        "api_errors",
        "frontend_errors",
        "lsp_failures"
      ],
      "properties": {
        "api_p95_ms": {
          "type": "integer",
          "minimum": 1
        },
        "api_errors": {
          "type": "integer",
          "minimum": 0
        },
        "frontend_errors": {
          "type": "integer",
          "minimum": 0
        },
        "lsp_failures": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
