{
  "description": "Request context contract for startup runtime inputs.",
  "type": "object",
  "required": [
    "phase",
    "deployment",
    "write_policy",
    "console",
    "request",
    "response"
  ],
  "properties": {
    "phase": {
      "const": "startup"
    },
    "deployment": {
      "type": "string",
      "enum": [
        "local",
        "hosted"
      ]
    },
    "write_policy": {
      "type": "string",
      "enum": [
        "disabled",
        "pull-request",
        "direct-push"
      ]
    },
    "console": {
      "type": "object",
      "required": [
        "host",
        "fixed_package",
        "secure_cookies"
      ],
      "properties": {
        "host": {
          "type": [
            "string",
            "null"
          ]
        },
        "fixed_package": {
          "type": "boolean"
        },
        "secure_cookies": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "request": {
      "type": "object",
      "required": [
        "present",
        "method",
        "route",
        "repo",
        "package",
        "branch",
        "mutating"
      ],
      "properties": {
        "present": {
          "type": "boolean"
        },
        "host": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "type": "string",
          "enum": [
            "none",
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE",
            "OPTIONS",
            "HEAD"
          ]
        },
        "route": {
          "type": "string"
        },
        "repo": {
          "type": [
            "string",
            "null"
          ]
        },
        "package": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "mutating": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": [
        "present",
        "status",
        "status_class",
        "latency_ms"
      ],
      "properties": {
        "present": {
          "type": "boolean"
        },
        "status": {
          "type": "integer",
          "minimum": 0,
          "maximum": 599
        },
        "status_class": {
          "type": "string",
          "enum": [
            "none",
            "success",
            "redirect",
            "client_error",
            "server_error"
          ]
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
