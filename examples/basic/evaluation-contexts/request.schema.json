{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Evaluation context contract for request runtime inputs.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "lane": {
      "type": "string"
    },
    "account": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "plan": {
          "type": "string"
        },
        "seats": {
          "type": "integer"
        }
      }
    },
    "cart": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "total_usd": {
          "type": "number"
        }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "platform": {
          "type": "string"
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "country": {
          "type": "string"
        }
      }
    },
    "user": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "email_domain": {
          "type": "string"
        },
        "id": {
          "type": [
            "string",
            "integer"
          ]
        },
        "language": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "session_count": {
          "type": "integer"
        },
        "tier": {
          "type": "string"
        }
      }
    }
  }
}
